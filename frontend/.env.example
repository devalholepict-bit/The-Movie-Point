# Frontend — Vite Environment Variables
# Copy this file to .env and fill in real values.
# All variables MUST start with VITE_ to be exposed to the browser bundle.

# ── TMDB API ──────────────────────────────────
# Get your API Read Access Token from https://www.themoviedb.org/settings/api
# Use the long "API Read Access Token (v4 auth)" — starts with eyJ...
VITE_TMDB_API_KEY=your_tmdb_read_access_token_here

# ── TMDB Base URLs (defaults shown — change only if TMDB updates their API) ──
VITE_TMDB_BASE_URL=https://api.themoviedb.org/3
VITE_TMDB_IMAGE_BASE=https://image.tmdb.org/t/p

# ── Backend API ───────────────────────────────
# Local development: point to the Express dev server
# Production on Vercel: use the same Vercel deployment URL  
# e.g. https://the-movie-point.vercel.app/api
VITE_API_BASE_URL=http://localhost:5000/api
