# Backend — Environment Variables
# Copy this file to .env and fill in real values before running locally or deploying.

# ── Server ────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── MongoDB Atlas ─────────────────────────────
# Get this from https://cloud.mongodb.com → your cluster → Connect → Drivers
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/moviepoint?retryWrites=true&w=majority

# ── JWT ───────────────────────────────────────
# Use a long, random string in production (e.g. openssl rand -hex 64)
JWT_SECRET=replace_with_a_very_long_random_secret_string
JWT_EXPIRE=30d
